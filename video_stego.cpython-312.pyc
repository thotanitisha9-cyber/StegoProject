import wave
import os

# 16-bit delimiter to be robust (length = 16)
DELIMITER = "1111111111111110"

def encode_audio(input_path, message, output_path):
    """
    Hides a secret message in a WAV file using LSB steganography.
    Modifies the Least Significant Bit of audio samples.
    """
    try:
        song = wave.open(input_path, mode='rb')
        params = song.getparams()
        n_frames = song.getnframes()
        frames = song.readframes(n_frames)
        frame_bytes = bytearray(list(frames))
        
        # Append delimiter
        message = message + DELIMITER
        
        # Convert message to bits
        binary_message = ''.join(format(ord(c), '08b') for c in message)
        
        # Determine step size based on sample width to minimize noise
        # 1 byte/sample (8-bit) -> modify every byte
        # 2 bytes/sample (16-bit) -> modify every 2nd byte (the LSB byte)
        # WAV is usually Little Endian, so for 16-bit, the first byte is LSB.
        # However, to be safe and simple, we'll try to just write sequentially 
        # but if we want to be "correct" for 16-bit, we should check.
        # For this implementation, we will treat the audio as a stream of bytes 
        # and modify LSB of each byte targeted. 
        # Note: Modifying MSB byte of a 16-bit sample induces significant noise.
        # We'll use a stride strategy if 16-bit.
        
        sampwidth = params.sampwidth
        stride = 1
        if sampwidth == 2:
            stride = 2 # Modify indices 0, 2, 4... (Low bytes)
            
        required_bytes = len(binary_message) * stride
        
        if required_bytes > len(frame_bytes):
            song.close()
            raise ValueError(f"Message too long. Need {required_bytes} bytes, have {len(frame_bytes)}")
            
        index = 0
        for i in range(len(binary_message)):
            # Determine byte index to modify
            byte_index = i * stride
            
            # Modify LSB
            frame_bytes[byte_index] = (frame_bytes[byte_index] & 254) | int(binary_message[index])
            index += 1
            
        # Write output
        with wave.open(output_path, 'wb') as fd:
            fd.setparams(params)
            fd.writeframes(bytes(frame_bytes))
            
        song.close()
        return True
        
    except Exception as e:
        print(f"Error encoding audio: {e}")
        return False

def decode_audio(stego_path):
    """
    Extracts a secret message from a WAV file.
    """
    try:
        song = wave.open(stego_path, mode='rb')
        params = song.getparams()
        n_frames = song.getnframes()
        frames = song.readframes(n_frames)
        frame_bytes = bytearray(list(frames))
        song.close()
        
        sampwidth = params.sampwidth
        stride = 1
        if sampwidth == 2:
            stride = 2
            
        extracted_bits = ""
        
        # Extract bits
        # We optimize by only extracting until we hit the delimiter?
        # But we don't know where it is.
        # Let's extract all "candidate" bits first, but maybe limit to a reasonable size 
        # or check periodically.
        
        # For simplicity in this demo, extract all sensible bits (this might be slow for large files)
        # Optimization: Generate bits generator
        
        def bits_generator():
            for i in range(0, len(frame_bytes), stride):
                yield str(frame_bytes[i] & 1)

        # Reconstruct string
        # We need to assemble bytes and check for delimiter
        
        delimiter_check = ""
        current_char_bits = ""
        decoded_msg = ""
        
        bit_stream = bits_generator()
        
        # We'll iterate and build chars
        # 16-bit delimiter is "1111111111111110"
        
        # Strategy: Accumulate full bit string is too heavy.
        # Accumulate bits, check for delimiter pattern at the end of what we have?
        # Actually, delimiter is likely at a byte boundary? Not necessarily if I added it as string.
        # Yes, I appended DELIMITER string "010101".
        # So I converted "1" to 8 bits?
        # WAIT. In encode_audio:
        # message = message + DELIMITER
        # binary_message = ''.join(format(ord(c), '08b') for c in message)
        # So the DELIMITER string is treated as TEXT chars.
        # "1" -> 00110001
        # That is NOT what I want for a delimiter normally.
        # Normally delimiter is a raw bit pattern.
        # But existing lsb.py in the project did:
        # binary_text = ''.join(format(ord(c), '08b') for c in text) + DELIMITER
        # So there, DELIMITER was a literal bit string appended to the bit stream.
        
        # I SHOULD DO THE SAME.
        
        # CORRECTION in ENCODE:
        # binary_message = ''.join(format(ord(c), '08b') for c in message) + DELIMITER
        pass
    except Exception as e:
        return f"Error: {e}"

# REDEFINING WITH CORRECT LOGIC
def encode_audio_v2(input_path, message, output_path):
    try:
        song = wave.open(input_path, mode='rb')
        params = song.getparams()
        n_frames = song.getnframes()
        frames = song.readframes(n_frames)
        frame_bytes = bytearray(list(frames))
        
        # Convert message to bits
        binary_message = ''.join(format(ord(c), '08b') for c in message)
        # Append raw delimiter bits
        binary_message += DELIMITER
        
        sampwidth = params.sampwidth
        stride = 1
        if sampwidth == 2:
            stride = 2
            
        if len(binary_message) * stride > len(frame_bytes):
            song.close()
            raise ValueError(f"Message too long.")
            
        for i in range(len(binary_message)):
            byte_index = i * stride
            frame_bytes[byte_index] = (frame_bytes[byte_index] & 254) | int(binary_message[i])
            
        with wave.open(output_path, 'wb') as fd:
            fd.setparams(params)
            fd.writeframes(bytes(frame_bytes))
        song.close()
        return True, "Stego audio created successfully."
    except Exception as e:
        print(f"Error: {e}")
        return False, str(e)

def decode_audio_v2(stego_path):
    try:
        song = wave.open(stego_path, mode='rb')
        params = song.getparams()
        frame_bytes = bytearray(list(song.readframes(song.getnframes())))
        song.close()
        
        sampwidth = params.sampwidth
        stride = 1
        if sampwidth == 2:
            stride = 2
            
        bits = ""
        # Search for delimiter window
        # This is a bit computationally expensive for python on large loops.
        # But assuming message is at start.
        
        max_len = len(frame_bytes) // stride
        
        # Optimization: Collect chunks
        chunk_size = 1000 # bits
        collected_bits = []
        
        for i in range(0, len(frame_bytes), stride):
            collected_bits.append(str(frame_bytes[i] & 1))
            
            # Check every now and then? No, let's just collect all? 
            # 5MB file -> 2.5M bits -> 2.5MB string. Fine.
            
        all_bits = "".join(collected_bits)
        
        delimiter_idx = all_bits.find(DELIMITER)
        if delimiter_idx != -1:
            binary_message = all_bits[:delimiter_idx]
            chars = []
            for i in range(0, len(binary_message), 8):
                byte = binary_message[i:i+8]
                if len(byte) == 8:
                    chars.append(chr(int(byte, 2)))
            return "".join(chars)
        else:
            return None
            
    except Exception as e:
        return None
