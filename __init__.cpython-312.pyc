import os
import random
import string
import sys
import urllib.request
from io import BytesIO
from PIL import Image

# Add project root to path to import src
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from src.core.lsb import encode_text_in_image
from src.core.security import encrypt_message

# Configuration
NUM_IMAGES = 50 
BASE_DIR = "NewDataset"
COVER_DIR = os.path.join(BASE_DIR, "cover")
STEGO_DIR = os.path.join(BASE_DIR, "stego")

def create_directories():
    os.makedirs(COVER_DIR, exist_ok=True)
    os.makedirs(STEGO_DIR, exist_ok=True)

def download_image(index):
    """Download a random image from picsum.photos using urllib"""
    url = f"https://picsum.photos/seed/{index}/300/300"
    path = os.path.join(COVER_DIR, f"cover_{index:03d}.png")
    
    if os.path.exists(path):
        print(f"Skipping download, {path} exists.")
        return path

    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as response:
            image_data = response.read()
            path = os.path.join(COVER_DIR, f"cover_{index:03d}.png")
            
            # Save as PNG
            img = Image.open(BytesIO(image_data)).convert("RGB")
            img.save(path, "PNG")
            return path
    except Exception as e:
        print(f"Failed to download image {index}: {e}")
    return None

def generate_random_text(length=100):
    letters = string.ascii_letters + string.digits + " "
    return ''.join(random.choice(letters) for i in range(length))

def create_stego_image(cover_path, index):
    try:
        # Fill about 20% to random length
        # Real encryption (starts with gAAAA...)
        secret_message = generate_random_text(random.randint(500, 2000))
        password = "dataset_password"
        
        # Use real encryption
        encrypted_text = encrypt_message(secret_message, password)
        
        stego_bytes_io = encode_text_in_image(encrypted_text, input_image=cover_path)
        
        stego_path = os.path.join(STEGO_DIR, f"stego_{index:03d}.png")
        with open(stego_path, "wb") as f:
            f.write(stego_bytes_io.read())
        return stego_path
    except Exception as e:
        print(f"Failed to generate stego image for {cover_path}: {e}")
        return None

def main():
    print(f"Starting Dataset Generation ({NUM_IMAGES} samples)...")
    create_directories()
    
    count = 0
    for i in range(1, NUM_IMAGES + 1):
        print(f"[{i}/{NUM_IMAGES}] Processing...")
        cover_path = download_image(i)
        
        if cover_path:
            stego_path = create_stego_image(cover_path, i)
            if stego_path:
                count += 1
        
    print(f"\nDataset creation complete! Generated {count} pairs.")
    print(f"Location: {os.path.abspath(BASE_DIR)}")

if __name__ == "__main__":
    main()
